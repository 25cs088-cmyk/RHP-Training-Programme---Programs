#include <iostream>
#include <string>
using namespace std;
int main(){
    string s;
    cin >> s;
    int maxLen = 0;
    int n = s.length();
    for(int i = 0; i < n; i++){
        int zeros = 0;
        int ones = 0;
        for(int j = i; j < n; j++){
            if(s[j] == '0')
                zeros++;
            else
                ones++;
            if(zeros == ones){
                int len = j - i + 1;
                if(len > maxLen)
                    maxLen = len;
            }
        }
    }
    cout << "Maximum Length = " << maxLen;
    return 0;
}
